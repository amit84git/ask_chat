# ============================================================
# AskChat - NL to SQL Platform Environment Configuration
# ============================================================
# Copy this to .env and adjust values for your environment.
# For local Floci deployment, the defaults work out of the box.
# For real AWS, switch to your actual AWS region and endpoints.
# ============================================================

# --- Application Settings ---
APP_NAME=AskChat
APP_ENV=local
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO

# --- AWS Endpoint Configuration (Floci vs Real AWS) ---
# For Floci: set AWS_ENDPOINT_URL=http://localhost:4566
# For real AWS: comment out or leave empty (boto3 will use default endpoints)
AWS_ENDPOINT_URL=http://localhost:4566

# --- AWS Region ---
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# --- AWS Credentials (use dummy values for Floci) ---
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# --- Floci Bedrock Runtime Endpoint ---
# Floci serves Bedrock at: http://localhost:4566/bedrock
# Override only if different from the standard AWS_ENDPOINT_URL
BEDROCK_ENDPOINT_URL=http://localhost:4566/bedrock

# --- S3 Configuration ---
S3_BUCKET_NAME=askchat-artifacts

# --- Database (PostgreSQL) ---
# For local container: use the values matching docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=askchat
DB_USER=askchat
DB_PASSWORD=askchat_secret_2024

# --- Secrets Manager ---
# DB secret name in Secrets Manager (if using RDS with Secrets Manager)
DB_SECRET_NAME=askchat/db-credentials

# --- LLM Provider Settings ---
# Provider options:
#   local / ollama / llama / mistral / phi / gemma = Ollama with open-source models (zero-cost)
#   claude / titan / bedrock = AWS Bedrock
#   none = heuristic-only mode (no LLM)
LLM_PROVIDER=ollama

# --- Ollama Local LLM Settings ---
# Ollama runs locally at http://localhost:11434
# Download models with: ollama pull llama3.1:8b
LOCAL_LLM_ENDPOINT=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b

# --- AWS Bedrock Settings (only used if LLM_PROVIDER=claude/titan/bedrock) ---
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-v2
BEDROCK_TITAN_MODEL_ID=amazon.titan-tg1-large

# Fallback to heuristic-only if LLM unavailable
LLM_FALLBACK_TO_HEURISTICS=true

# --- Feature Flags ---
FEATURE_RULES_ENGINE=true
FEATURE_FUZZY_MATCHING=true
FEATURE_SEMANTIC_GRAPH=true
FEATURE_BEDROCK=false

# --- CORS ---
CORS_ORIGINS=*

# --- Visualization ---
VIS_OUTPUT_DIR=./output/visualizations

# --- spaCy Model ---
# Download with: python -m spacy download en_core_web_sm
SPACY_MODEL=en_core_web_sm